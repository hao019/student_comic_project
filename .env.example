# Copy this file to .env and fill in your real Gemini API key.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image

# Optional local FLUX.1 Kontext [dev] image server.
# Start your local inference server separately, then choose
# "FLUX.1 Kontext dev local" in the UI.
# For FLUX.1 Kontext [dev] diffusers mode, accept the model terms on
# Hugging Face and provide a token with access to the gated repository.
HF_TOKEN=your_huggingface_token_with_flux_kontext_access
FLUX_KONTEXT_LOCAL_URL=http://127.0.0.1:7860/generate
FLUX_KONTEXT_LOCAL_BACKEND=diffusers
FLUX_KONTEXT_DIFFUSERS_MODEL_ID=black-forest-labs/FLUX.1-Kontext-dev
FLUX_KONTEXT_LOCAL_MODEL=flux.1-kontext-dev
FLUX_KONTEXT_LOCAL_WIDTH=1024
FLUX_KONTEXT_LOCAL_HEIGHT=1024
FLUX_KONTEXT_LOCAL_TIMEOUT=300
FLUX_KONTEXT_LOCAL_STEPS=28
FLUX_KONTEXT_LOCAL_GUIDANCE=3.5
FLUX_KONTEXT_LOCAL_MAX_SEQUENCE_LENGTH=512

# Google OAuth + Drive upload settings.
# In Google Cloud Console, add this redirect URI:
# http://127.0.0.1:8000/auth/google/callback
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret_here
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/auth/google/callback
GOOGLE_DRIVE_FOLDER_NAME=Student Comic Generator
